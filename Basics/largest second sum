# cook your dish
t=int(input())
while(t>0):
    n=int(input())
    m=list(map(int,input().split()))
    largest=m[0]
    second=0
    t-=1
    for i in range(1,n):
        if(m[i]>largest):
            second=largest
            largest=m[i]
            sum1=largest+second
        elif(m[i]>second and m[i]!=largest):
            second=m[i]
            sum1=largest+second
    print(sum1)
        
